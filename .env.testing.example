# Sisly Integration Test Configuration
#
# Copy this file to .env.testing and add your API keys to run integration tests.
#
# Run integration tests with:
#   composer test:integration
#
# Or directly:
#   ./vendor/bin/phpunit --testsuite Integration
#

# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4-turbo

# Gemini Configuration (optional, for failover testing)
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-pro

# LLM Driver (openai or gemini)
SISLY_LLM_DRIVER=openai

# Enable failover between providers
SISLY_LLM_FAILOVER=true
